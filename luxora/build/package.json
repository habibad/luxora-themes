{
  "name": "luxora-theme-build",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind CSS v4 build pipeline for the Luxora WordPress theme.",
  "scripts": {
    "build": "tailwindcss -i input.css -o ../assets/css/main.css --minify",
    "watch": "tailwindcss -i input.css -o ../assets/css/main.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2"
  }
}
